# API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model Configuration
EMBEDDING_MODEL=all-MiniLM-L6-v2
LLM_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=4096
TEMPERATURE=0.7

# Vector Database
VECTOR_DB_PATH=./data/vectordb
VECTOR_DB_TYPE=chromadb  # chromadb or faiss

# Chunking Strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=128
MAX_CHUNKS_PER_DOC=50

# Retrieval Configuration
TOP_K=10
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.7
ENABLE_RERANKING=true
ENABLE_HYBRID_SEARCH=true

# Multi-Intent Configuration
ENABLE_MULTI_INTENT=true
MAX_SUB_QUERIES=3

# Cache Configuration
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_DIR=./data/cache

# Data Ingestion
STACKOVERFLOW_DATA_PATH=./data/raw/stackoverflow
MAX_DOCUMENTS=50000
MIN_SCORE=5  # Minimum Stack Overflow score to include
MIN_ANSWER_LENGTH=100

# Application Settings
APP_NAME=Advanced RAG Chatbot
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4
RELOAD=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# CORS
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,PUT,DELETE
ALLOWED_HEADERS=*
